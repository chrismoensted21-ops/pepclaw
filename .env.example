# =============================================================================
# Pepclaw — environment configuration
# Copy to `.env.local` and fill in your keys. Nothing here is required to boot;
# every key has a deterministic fallback so you can run the swarm offline.
# =============================================================================

# -----------------------------------------------------------------------------
# kie.ai LLM — powers Thesis Generator, Red Team, Synthesizer (reasoning pools)
# Endpoint: POST {KIE_BASE_URL}/codex/v1/responses
# Auth:     Authorization: Bearer ${KIE_API_KEY}
# Model:    gpt-5-4 (reasoning, multimodal, JSON-tool-calling)
# Without KIE_API_KEY, agents use a deterministic templated fallback.
# -----------------------------------------------------------------------------
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_MODEL=gpt-5-4
# low | medium | high | xhigh — passed as `reasoning.effort`
KIE_REASONING_EFFORT=medium

# -----------------------------------------------------------------------------
# Pepclaw runtime
# -----------------------------------------------------------------------------
# Persistent SQLite DB path. Relative paths resolve from cwd.
PEPCLAW_DB_PATH=.data/pepclaw.db
# Default per-mission budget in USD cents (used when caller omits one).
PEPCLAW_DEFAULT_BUDGET_CENTS=800
# Header label shown in Mission Control.
PEPCLAW_ENV=dev
PEPCLAW_REGION=local

# -----------------------------------------------------------------------------
# Biomedical data sources (all optional, all have public anonymous tiers)
# -----------------------------------------------------------------------------

# NCBI E-utilities (PubMed). An API key raises the rate limit from 3 → 10 req/s.
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
# Required by NCBI's terms — set to a contact email so they can reach you on abuse.
NCBI_EMAIL=

# UniProt — no key required, but a contact UA helps if you exceed limits.
UNIPROT_USER_AGENT=Pepclaw/0.1 (your-email@domain)

# OpenTargets GraphQL — no key required for public schema.
OPENTARGETS_URL=https://api.platform.opentargets.org/api/v4/graphql

# ChEMBL REST — no key required.
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data

# AlphaFold (EBI) — no key required.
ALPHAFOLD_BASE_URL=https://alphafold.ebi.ac.uk/api

# Reactome — no key required.
REACTOME_BASE_URL=https://reactome.org/ContentService

# Lens.org Patents (future — leave blank to disable patent pool).
# Get a token at https://www.lens.org/lens/user/subscriptions
LENS_API_TOKEN=

# -----------------------------------------------------------------------------
# Server-side fetch tuning
# -----------------------------------------------------------------------------
# Soft per-call timeout in ms for source clients.
SOURCE_FETCH_TIMEOUT_MS=15000
# Maximum results requested per upstream pool call.
SOURCE_MAX_RESULTS=12

# -----------------------------------------------------------------------------
# Optional — skip on first run, only used in production deployments
# -----------------------------------------------------------------------------
# Origin used for absolute URL generation in metadata (OG tags etc.).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "1" to require commit-hash verification before /api/missions accepts a write.
PEPCLAW_REQUIRE_COMMIT=
