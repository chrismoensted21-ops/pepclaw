# =============================================================================
# Pepclaw — environment configuration
# Copy to `.env.local` and fill in only the two SUPABASE keys + KIE_API_KEY.
# Everything else has a sane default.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — primary persistence (Postgres)
# 1. Create a project at https://supabase.com
# 2. Settings → API → copy the Project URL into NEXT_PUBLIC_SUPABASE_URL
# 3. Settings → API → copy the `service_role` secret into SUPABASE_SERVICE_ROLE_KEY
#    (NEVER expose it to the browser — server-side only)
# 4. SQL Editor → paste the contents of `supabase/schema.sql` and run it
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://wqasdcaxoxxptjwemdgy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndxYXNkY2F4b3h4cHRqd2VtZGd5Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NzEzODE2OSwiZXhwIjoyMDkyNzE0MTY5fQ.LVgyn7LTyzhO70awtBFM8xPXtDFU9K7xN-YVt638kbQ

# -----------------------------------------------------------------------------
# kie.ai LLM — powers Thesis Generator, Red Team, Synthesizer
# Endpoint: POST {KIE_BASE_URL}/codex/v1/responses
# Auth:     Authorization: Bearer ${KIE_API_KEY}
# Without KIE_API_KEY, agents use a deterministic templated fallback so the
# swarm still runs end-to-end (useful for first-run / demo).
# -----------------------------------------------------------------------------
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_MODEL=gpt-5-4
KIE_REASONING_EFFORT=medium

# -----------------------------------------------------------------------------
# Pepclaw runtime — pre-filled defaults, change if you want
# -----------------------------------------------------------------------------
PEPCLAW_DEFAULT_BUDGET_CENTS=800
PEPCLAW_ENV=dev
PEPCLAW_REGION=local
NEXT_PUBLIC_APP_URL=https://pepclaw.money

# -----------------------------------------------------------------------------
# Public biomedical data sources — pre-filled, work without keys
# -----------------------------------------------------------------------------
OPENTARGETS_URL=https://api.platform.opentargets.org/api/v4/graphql
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data
ALPHAFOLD_BASE_URL=https://alphafold.ebi.ac.uk/api
REACTOME_BASE_URL=https://reactome.org/ContentService

# -----------------------------------------------------------------------------
# Server-side fetch tuning — pre-filled, change for slow networks
# -----------------------------------------------------------------------------
SOURCE_FETCH_TIMEOUT_MS=15000
SOURCE_MAX_RESULTS=12
